#include<stdio.h>
int main()
{
    int t;  
    for(t=1;t<=2;t++)   // Loop for 2 test cases
    {
        int n,i,j,visited[10]={0};
        int cost[10][10],min,a,b,u,v,total=0;
        printf("\n--- Test Case %d ---\n",t);
        printf("Enter number of vertices: ");
        scanf("%d",&n);
        printf("Enter cost matrix:\n");
        for(i=0;i<n;i++)
        {
            for(j=0;j<n;j++)
            {
                scanf("%d",&cost[i][j]);
                if(cost[i][j]==0)
                    cost[i][j]=999;
            }}
        visited[0]=1;
        for(i=0;i<n-1;i++)
        {
        min=999;
        for(u=0;u<n;u++)
        {
        if(visited[u])
        {
        for(v=0;v<n;v++)
        {
        if(!visited[v] && cost[u][v]<min)
        {
        min=cost[u][v];
        a=u;
        b=v;
        }}}}
        printf("Edge %d:(%d %d) cost:%d\n",i+1,a,b,min);
        total+=min;
        visited[b]=1;
        }
        printf("Minimum Cost = %d\n",total);
        }
        return 0;
}
