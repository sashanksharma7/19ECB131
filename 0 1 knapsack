#include<stdio.h>

int max(int a,int b)
{
    return (a>b)?a:b;
}

int main()
{
    int n,w,i,j;
    int wt[10],p[10],K[10][10];

    for(int test=1; test<=2; test++)
    {
        printf("\nTest Case %d\n",test);

        printf("Enter number of items: ");
        scanf("%d",&n);

        printf("Enter weights:\n");
        for(i=1;i<=n;i++)
        scanf("%d",&wt[i]);

        printf("Enter profits:\n");
        for(i=1;i<=n;i++)
        scanf("%d",&p[i]);

        printf("Enter capacity: ");
        scanf("%d",&w);

        for(i=0;i<=n;i++)
        for(j=0;j<=w;j++)
        {
            if(i==0 || j==0)
            K[i][j]=0;
            else if(wt[i]<=j)
            K[i][j]=max(p[i]+K[i-1][j-wt[i]],K[i-1][j]);
            else
            K[i][j]=K[i-1][j];
        }

        printf("Maximum Profit = %d\n",K[n][w]);
    }
}
