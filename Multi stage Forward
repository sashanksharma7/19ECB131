#include<stdio.h>
int main()
{
int t;
for(t=1;t<=2;t++)   // Loop for 2 test cases
{
int n,i,j;
int cost[10][10],dist[10];
printf("\n--- Test Case %d ---\n",t);
printf("Enter number of vertices: ");
scanf("%d",&n);
printf("Enter cost matrix:\n");
for(i=0;i<n;i++)
for(j=0;j<n;j++)
scanf("%d",&cost[i][j]);
dist[0]=0;
for(i=1;i<n;i++)
dist[i]=999;
for(i=0;i<n;i++)
{
for(j=0;j<n;j++)
{
if(cost[i][j]!=0 && dist[j] > dist[i]+cost[i][j])
dist[j]=dist[i]+cost[i][j];
}}
printf("Minimum cost to reach last vertex = %d\n",dist[n-1]);
}
return 0;
}
