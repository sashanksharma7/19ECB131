#include<stdio.h>

int main()
{
    int t,i,j,n;
    float profit[20],weight[20],ratio[20];
    float capacity,total,temp;
    for(t=1;t<=2;t++)  
    {
        total=0;
        printf("\n--- Test Case %d ---\n",t);
        printf("Enter number of items: ");
        scanf("%d",&n);
        for(i=0;i<n;i++)
        {
            printf("Enter profit and weight of item %d: ",i+1);
            scanf("%f%f",&profit[i],&weight[i]);
            ratio[i]=profit[i]/weight[i];
        }
        printf("Enter knapsack capacity: ");
        scanf("%f",&capacity);
        for(i=0;i<n;i++)
        {
            for(j=i+1;j<n;j++)
            {
                if(ratio[i]<ratio[j])
                {
                    temp=ratio[i];
                    ratio[i]=ratio[j];
                    ratio[j]=temp
                    temp=profit[i];
                    profit[i]=profit[j];
                    profit[j]=temp;
                    temp=weight[i];
                    weight[i]=weight[j];
                    weight[j]=temp;
                }}}
        for(i=0;i<n;i++)
        {
            if(weight[i]<=capacity)
            {
                total=total+profit[i];
                capacity=capacity-weight[i];
            }
            else
            {
                total=total+(profit[i]/weight[i])*capacity;
                break;
            }
        }
        printf("Maximum Profit = %.2f\n",total);
    }
    return 0;
}
