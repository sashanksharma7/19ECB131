#include<stdio.h>
int main()
{
int t;
for(t=1;t<=2;t++)   // Loop for 2 test cases
{
int n,i,j;
int cost[10][10],dist[10];
printf("\n--- Test Case %d ---\n",t);
printf("Enter number of vertices: ");
scanf("%d",&n);
printf("Enter cost matrix:\n");
for(i=0;i<n;i++)
for(j=0;j<n;j++)
scanf("%d",&cost[i][j]);
dist[n-1]=0;
for(i=n-2;i>=0;i--)
{
dist[i]=999;
for(j=i+1;j<n;j++)
{
if(cost[i][j]!=0 && cost[i][j]+dist[j] < dist[i])
dist[i]=cost[i][j]+dist[j];
}
}
printf("Minimum cost from source = %d\n",dist[0]);
}
return 0;
}
