#include<stdio.h>

int min(int a,int b)
{
    if(a<b) return a;
    else return b;
}

int main()
{
    int n,i,j,k;
    int a[10][10];

    for(int test=1; test<=2; test++)
    {
        printf("\nTest Case %d\n",test);

        printf("Enter number of vertices: ");
        scanf("%d",&n);

        printf("Enter cost matrix:\n");
        for(i=0;i<n;i++)
        for(j=0;j<n;j++)
        scanf("%d",&a[i][j]);

        for(k=0;k<n;k++)
        for(i=0;i<n;i++)
        for(j=0;j<n;j++)
        a[i][j]=min(a[i][j],a[i][k]+a[k][j]);

        printf("Shortest Path Matrix:\n");
        for(i=0;i<n;i++)
        {
            for(j=0;j<n;j++)
            printf("%d ",a[i][j]);
            printf("\n");
        }
    }
}
